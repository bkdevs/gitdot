RUST_LOG=debug

# Git repository storage location
# Production: /srv/git
# Development: Use a local directory like ~/Desktop/repos, /tmp/ maybe auto-collected beware
GIT_PROJECT_ROOT=/srv/git

# Posgres direct connection URI
DATABASE_URL=postgresql://postgres:[PASSWORD_HERE]@db.[PROJECT_ID_HERE].supabase.co:5432/postgres

# Optional Slack webhook for internal post-receive debug notifications
# If unset, Slack messages for post-receive will be skipped
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Supabase public key
SUPABASE_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
...
...
-----END PUBLIC KEY-----"

# OAuth device flow verfication URI
OAUTH_DEVICE_VERIFICATION_URI=https://your-url.com/path

# GCP Project ID for secret manager
GCP_PROJECT_ID=PROJECT_ID

# Ed25519 keypair for signing
# Generate with: just generate-keys
# In production, store the private key as GCP secret "gitdot-private-key" instead
GITDOT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
...
-----END PRIVATE KEY-----"
GITDOT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
...
-----END PUBLIC KEY-----"
